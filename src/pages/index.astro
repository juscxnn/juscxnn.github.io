---
import "@fontsource/instrument-serif/400.css";
import "@fontsource/dm-sans/400.css";
import "@fontsource/dm-sans/500.css";
import "@fontsource/dm-sans/600.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "../styles/global.css";
import fs from "node:fs";

const LINKS = {
  GATEKEEP: "https://gatekeep.vc",
  ATTITEUD: "https://attiteud.com",
  NICHESIM: "https://nichesim.com",
  CLIQUE: "https://clique.tech",
  ZAOBAO: "https://www.zaobao.com.sg/news/singapore/story20240102-1459510",
  LINKEDIN: "https://linkedin.com/in/justincxa",
  GITHUB: "https://github.com/juscxnn",
  SOURCE: "https://github.com/juscxnn/juscxnn.github.io",
};
const EMAIL = "jcxa@proton.me";

const hasPortrait = fs.existsSync(new URL("../../public/portrait.jpg", import.meta.url));

const faviconSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><g fill="#1C5C3A">${[0, 60, 120, 180, 240, 300]
  .map((a) => `<ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(${a} 16 16)"/>`)
  .join("")}</g></svg>`;
const favicon = `data:image/svg+xml,${encodeURIComponent(faviconSvg)}`;

const description = "Justin Chua — software, distribution, private markets. Taipei.";
const ogImage = new URL("/og.png", Astro.site);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Justin Chua",
  url: Astro.site?.toString(),
  email: `mailto:${EMAIL}`,
  description,
  address: { "@type": "PostalAddress", addressLocality: "Taipei" },
  knowsLanguage: ["en", "zh", "fr"],
  sameAs: [LINKS.LINKEDIN, LINKS.GITHUB, LINKS.GATEKEEP, LINKS.ATTITEUD, LINKS.NICHESIM],
});

const projects = [
  {
    name: "Gatekeep",
    desc: "Founder and VC discovery at scale.",
    href: LINKS.GATEKEEP,
    domain: "gatekeep.vc",
    logo: "/logos/gatekeep.svg",
    shot: "/shots/gatekeep.jpg",
  },
  {
    name: "Attiteud",
    desc: "Buys and builds AI-native software.",
    href: LINKS.ATTITEUD,
    domain: "attiteud.com",
    logo: "/logos/attiteud.png",
    shot: "/shots/attiteud.jpg",
  },
  {
    name: "Nichesim",
    desc: "Simulate communities to test ideas.",
    href: LINKS.NICHESIM,
    domain: "nichesim.com",
    logo: "/logos/nichesim.svg",
    shot: "/shots/nichesim.jpg",
  },
  {
    name: "Signal",
    desc: "Exchange intelligence at Clique.",
    href: LINKS.CLIQUE,
    domain: "clique.tech",
    logo: "/logos/clique.png",
    shot: "/shots/clique.jpg",
  },
];

const stack = [
  "TypeScript",
  "Node.js",
  "Next.js",
  "Astro",
  "Python",
  "Postgres",
  "SQLite",
  "Electron",
  "LLM pipelines",
  "RAG + agents",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Justin Chua</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.site} />
    <meta name="theme-color" content="#F7F4EC" />
    <meta property="og:title" content="Justin Chua" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#top">skip to content</a>

    <header class="nav">
      <nav class="wrap nav-inner" aria-label="Primary">
        <a class="wordmark" href="#top">Justin Chua</a>
        <ul class="nav-links">
          <li><a href="#track-record">track record</a></li>
          <li><a href="#building-now">building</a></li>
          <li><a href="#work">work</a></li>
          <li><a href="#private-markets">private markets</a></li>
          <li class="lang"><span title="中文版 coming soon">EN / 繁中</span></li>
        </ul>
      </nav>
    </header>

    <main id="top">
      <section class="section" aria-label="Introduction">
        <div class="wrap hero-grid">
          <div class="hero-text">
            <p class="eyebrow">TAIPEI · SG · EN ZH FR</p>
            <h1>I build software and get it distributed.</h1>
          </div>
          <div class="hero-media">
            {
              hasPortrait ? (
                <img class="portrait" src="/portrait.jpg" alt="Justin Chua" width="600" height="800" />
              ) : (
                <div class="portrait-fallback" aria-hidden="true">
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <g fill="#1C5C3A">
                      <ellipse cx="16" cy="8.5" rx="4" ry="7.5" />
                      <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(60 16 16)" />
                      <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(120 16 16)" />
                      <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(180 16 16)" />
                      <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(240 16 16)" />
                      <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(300 16 16)" />
                    </g>
                  </svg>
                </div>
              )
            }
          </div>
        </div>
      </section>

      <section class="section section--tight" aria-label="Career timeline">
        <div class="wrap">
          <p class="timeline-strip">
            <span class="t">2014 police SOC</span><span class="dot">·</span><span class="t"
              >2017 robotics sales</span
            ><span class="dot">·</span><span class="t">2020 maritime</span><span class="dot">·</span
            ><span class="t">2022 CopyScouts exit 14x</span><span class="dot">·</span><span class="t"
              >2024 Podletter exit 7x</span
            ><span class="dot">·</span><span class="t">2025 Clique</span><span class="dot">·</span
            ><span class="t t--now">2026 Attiteud + Gatekeep</span>
          </p>
        </div>
      </section>

      <section id="track-record" class="section" aria-label="Track record">
        <div class="wrap">
          <p class="eyebrow">01 · TRACK RECORD</p>
          <div class="grid grid--3">
            <article class="card">
              <p class="card-eyebrow">maritime · 2020–24</p>
              <p class="card-number">75%</p>
              <p class="card-body">
                of Singapore's harbour craft market digitalized at elxa.
              </p>
              <a class="card-link" href={LINKS.ZAOBAO} rel="noopener" lang="zh-Hans"
                >联合早报 · jan 2024 →</a
              >
            </article>
            <article class="card">
              <p class="card-eyebrow">ai saas · 2022–24</p>
              <p class="card-number">2 exits</p>
              <p class="card-body">
                CopyScouts sold at 14x. Podletter acquired 2024. AI Starter #2 on Product Hunt.
              </p>
            </article>
            <!-- PENDING internal clearance on figures. -->
            <article class="card">
              <p class="card-eyebrow">crypto · 2025–</p>
              <p class="card-number">US$10bn+</p>
              <p class="card-body">
                in token value distributed at Clique — Berachain, EigenLayer, Babylon.
              </p>
              <a class="card-link" href={LINKS.CLIQUE} rel="noopener">clique.tech →</a>
            </article>
          </div>
        </div>
      </section>

      <section id="building-now" class="section" aria-label="Building now">
        <div class="wrap">
          <p class="eyebrow">02 · BUILDING NOW</p>
          <div class="grid grid--4">
            {
              projects.map((p) => (
                <a class="tile" href={p.href} rel="noopener">
                  <span class="tile-thumb">
                    <img
                      src={p.shot}
                      alt={`${p.name} — screenshot`}
                      width="560"
                      height="350"
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                  <span class="tile-body">
                    <span class="tile-head">
                      <img
                        class="tile-logo"
                        src={p.logo}
                        alt=""
                        width="22"
                        height="22"
                        loading="lazy"
                        decoding="async"
                      />
                      <span class="tile-name">{p.name}</span>
                    </span>
                    <span class="tile-desc">{p.desc}</span>
                    <span class="tile-domain">{p.domain} →</span>
                  </span>
                </a>
              ))
            }
          </div>
          <p class="stack-line">stack: {stack.join(" · ")}</p>
        </div>
      </section>

      <section id="work" class="section" aria-label="Work with me">
        <div class="wrap">
          <p class="eyebrow">03 · WORK WITH ME</p>
          <div class="grid grid--3">
            <a class="route" href={LINKS.ATTITEUD} rel="noopener">
              <p class="route-title">SaaS acquisitions · AI deployment</p>
              <p class="route-sub">attiteud.com</p>
            </a>
            <a class="route" href={`mailto:${EMAIL}`}>
              <p class="route-title">Brand collaboration</p>
              <p class="route-sub">EN or 中文 · {EMAIL}</p>
            </a>
            <a class="route route--green" href="#private-markets">
              <p class="route-title">Private markets</p>
              <p class="route-sub">secondaries · structured deals</p>
            </a>
          </div>
          <p class="partners-line">
            content partners: Fieldy AI · Plaud · Aethir · Zalora ·
            <a href={`mailto:${EMAIL}`}>media kit →</a>
          </p>
        </div>
      </section>

      <section id="private-markets" class="section" aria-label="Private markets">
        <div class="wrap">
          <p class="eyebrow">04 · PRIVATE MARKETS</p>
          <p class="statement">
            Pre-IPO secondaries and structured private deals, buy-side and sell-side.
          </p>
          <p class="coverage">
            current coverage: AI pre-IPO names you'd recognize · share tokenization · listco
            collateral lending, tokenized + traditional
          </p>
          <div class="cta-row">
            <a class="pill" href={`mailto:${EMAIL}?subject=Deal%20sheet`}
              >request the live deal sheet →</a
            >
            <a class="text-cta" href={LINKS.LINKEDIN} rel="noopener">or DM on LinkedIn →</a>
          </div>
          <p class="disclaimer">
            accredited and professional investors · indications of interest only
          </p>
        </div>
      </section>

      <section class="section section--tight" aria-label="Background">
        <div class="wrap">
          <p class="bio-line">
            before tech: police special operations command. also: Mr World Singapore finalist.
          </p>
          <p class="colophon">
            this site: astro static · zero client js · self-hosted type ·
            <a href={LINKS.SOURCE} rel="noopener">view source →</a>
          </p>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <p class="footer-copy">© Justin Chua · Taipei</p>
        <div class="socials">
          <a href={LINKS.LINKEDIN} aria-label="LinkedIn" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.125 2.062 2.062 0 0 1 0 4.125zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              /></svg
            >
          </a>
          <a href={LINKS.GITHUB} aria-label="GitHub" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              /></svg
            >
          </a>
          <a href={`mailto:${EMAIL}`} aria-label="Email">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
              /></svg
            >
          </a>
        </div>
        <!-- Digital twin embed: drop the chatbot script here later. It mounts into #twin-mount. -->
        <div id="twin-mount"></div>
      </div>
    </footer>
  </body>
</html>
