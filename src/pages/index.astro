---
import "../styles/global.css";
import fs from "node:fs";

// Fill these once real URLs exist. Leave the {{TOKEN}} strings as-is until then.
const TOKENS = {
  GATEKEEP_URL: "{{GATEKEEP_URL}}",
  ATTITEUD_URL: "{{ATTITEUD_URL}}",
  SIGNAL_URL: "{{SIGNAL_URL}}",
  HANDLESTACK_URL: "{{HANDLESTACK_URL}}",
  FDS_URL: "{{FDS_URL}}",
  TELEGRAM_URL: "{{TELEGRAM_URL}}",
};

const EMAIL = "jcxa@proton.me";
const LINKEDIN_URL = "https://linkedin.com/in/justincxa";
const GITHUB_URL = "https://github.com/juscxnn";

const hasPortrait = fs.existsSync(new URL("../../public/portrait.jpg", import.meta.url));

const faviconSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><g fill="#1C5C3A">${[0, 60, 120, 180, 240, 300]
  .map((a) => `<ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(${a} 16 16)"/>`)
  .join("")}</g></svg>`;
const favicon = `data:image/svg+xml,${encodeURIComponent(faviconSvg)}`;

const description =
  "I build software and get it distributed. Two exits, US$10bn+ distributed at Clique, a decade across maritime, AI and crypto.";
const ogImage = new URL("/og.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Justin Chua</title>
    <meta name="description" content={description} />
    <meta property="og:title" content="Justin Chua" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <header class="nav">
      <nav class="wrap nav-inner" aria-label="Primary">
        <a class="wordmark" href="#top">Justin Chua</a>
        <ul class="nav-links">
          <li><a href="#track-record">track record</a></li>
          <li><a href="#work">work</a></li>
          <li><a href="#partnerships">partnerships</a></li>
          <li><a href="#private-markets">private markets</a></li>
          <li class="lang"><span title="中文版 coming soon">EN / 繁中</span></li>
        </ul>
      </nav>
    </header>

    <main id="top">
      <section class="section" aria-label="Introduction">
        <div class="wrap hero-grid">
          <div class="hero-text">
            <p class="eyebrow">TAIPEI · SG · EN ZH FR</p>
            <h1>I build software and get it distributed.</h1>
            <p class="lede">
              Two exits. US$10bn+ in token value distributed at Clique. A decade across maritime,
              AI and crypto.
            </p>
          </div>
          <div class="hero-media">
            {
              hasPortrait ? (
                <img class="portrait" src="/portrait.jpg" alt="Justin Chua" width="600" height="800" />
              ) : (
                <div class="portrait-fallback"><span>portrait</span></div>
              )
            }
          </div>
        </div>
      </section>

      <section class="section section--tight" aria-label="Career timeline">
        <div class="wrap">
          <p class="timeline-strip">
            <span class="t">2014 police SOC</span><span class="dot">·</span><span class="t"
              >2017 robotics sales</span
            ><span class="dot">·</span><span class="t">2020 maritime</span><span class="dot">·</span
            ><span class="t">2022 CopyScouts exit 14x</span><span class="dot">·</span><span class="t"
              >2024 Podletter exit 7x</span
            ><span class="dot">·</span><span class="t">2025 Clique</span><span class="dot">·</span
            ><span class="t t--now">2026 Attiteud + Gatekeep</span>
          </p>
        </div>
      </section>

      <section id="track-record" class="section" aria-label="Track record">
        <div class="wrap">
          <p class="eyebrow">01 · TRACK RECORD</p>
          <div class="grid grid--3">
            <article class="card">
              <p class="card-eyebrow">maritime · 2020–24</p>
              <p class="card-number">75%</p>
              <p class="card-body">
                of Singapore's domestic harbour craft market digitalized at elxa, the country's #6
                fastest-growing company. Four years inside ShipsFocus Ventures.
              </p>
            </article>
            <article class="card">
              <p class="card-eyebrow">ai saas · 2022–24</p>
              <p class="card-number">2 exits</p>
              <p class="card-body">
                CopyScouts, built before ChatGPT, sold at 14x. Podletter, acquired 2024. AI Starter
                hit #2 on Product Hunt.
              </p>
            </article>
            <!-- PENDING internal clearance on figures. -->
            <article class="card">
              <p class="card-eyebrow">crypto · 2025–</p>
              <p class="card-number">US$10bn+</p>
              <p class="card-body">
                in token value distributed at Clique for Berachain, EigenLayer, Babylon and more.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="building-now" class="section" aria-label="Building now">
        <div class="wrap">
          <p class="eyebrow">02 · BUILDING NOW</p>
          <div class="grid grid--4">
            <a class="tile" href={TOKENS.GATEKEEP_URL}>
              <p class="tile-name">Gatekeep</p>
              <p class="tile-desc">Founder and VC discovery at scale.</p>
            </a>
            <a class="tile" href={TOKENS.ATTITEUD_URL}>
              <p class="tile-name">Attiteud</p>
              <p class="tile-desc">Buys and builds AI-native software.</p>
            </a>
            <a class="tile" href={TOKENS.SIGNAL_URL}>
              <p class="tile-name">Signal</p>
              <p class="tile-desc">Exchange intelligence at Clique.</p>
            </a>
            <a class="tile" href={TOKENS.HANDLESTACK_URL}>
              <p class="tile-name">Handlestack</p>
              <p class="tile-desc">Free handle checker for founders.</p>
            </a>
          </div>
        </div>
      </section>

      <section id="partnerships" class="section" aria-label="Partnerships">
        <div class="wrap">
          <p class="eyebrow">03 · PARTNERSHIPS</p>
          <p class="intro">
            I create tech and lifestyle content in English and Chinese. Selected partners:
          </p>
          <ul class="chips">
            <li class="chip">Fieldy AI</li>
            <li class="chip">Plaud</li>
            <li class="chip">Aethir</li>
            <li class="chip">Zalora</li>
            <li class="chip">fitness + aesthetics</li>
          </ul>
          <a class="text-cta" href={`mailto:${EMAIL}`}>request media kit →</a>
        </div>
      </section>

      <section id="work" class="section" aria-label="Work with me">
        <div class="wrap">
          <p class="eyebrow">04 · WORK WITH ME</p>
          <div class="grid grid--4">
            <a class="route" href={TOKENS.ATTITEUD_URL}>
              <p class="route-title">Selling a small SaaS</p>
              <p class="route-sub">Attiteud criteria</p>
            </a>
            <a class="route" href={TOKENS.FDS_URL}>
              <p class="route-title">Deploy AI in your team</p>
              <p class="route-sub">Forward Deployment Studio</p>
            </a>
            <a class="route" href={`mailto:${EMAIL}`}>
              <p class="route-title">Brand collaboration</p>
              <p class="route-sub">EN or 中文, direct line</p>
            </a>
            <a class="route route--green" href="#private-markets">
              <p class="route-title">Private markets</p>
              <p class="route-sub">Secondaries and structured deals</p>
            </a>
          </div>
        </div>
      </section>

      <section id="private-markets" class="section" aria-label="Private markets">
        <div class="wrap">
          <p class="eyebrow">05 · PRIVATE MARKETS</p>
          <p class="statement">
            I broker pre-IPO secondaries and structured private deals, buy-side and sell-side.
          </p>
          <p class="coverage">
            current coverage: AI pre-IPO names you'd recognize · share tokenization · listco
            collateral lending, tokenized + traditional
          </p>
          <div class="cta-row">
            <a class="pill" href={TOKENS.TELEGRAM_URL}>
              <svg viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
                /></svg
              >
              message for the live deal sheet →
            </a>
            <a class="text-cta" href={LINKEDIN_URL}>or DM on LinkedIn →</a>
          </div>
          <p class="disclaimer">
            accredited and professional investors · indications of interest only
          </p>
        </div>
      </section>

      <section class="section section--tight" aria-label="Background">
        <div class="wrap">
          <p class="bio-line">
            before tech: police special operations command. also: Mr World Singapore finalist.
          </p>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <p class="footer-copy">© Justin Chua · Taipei</p>
        <div class="socials">
          <a href={LINKEDIN_URL} aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.125 2.062 2.062 0 0 1 0 4.125zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              /></svg
            >
          </a>
          <a href={TOKENS.TELEGRAM_URL} aria-label="Telegram">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
              /></svg
            >
          </a>
          <a href={GITHUB_URL} aria-label="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              /></svg
            >
          </a>
        </div>
        <!-- Digital twin embed: drop the chatbot script here later. It mounts into #twin-mount. -->
        <div id="twin-mount"></div>
      </div>
    </footer>
  </body>
</html>
