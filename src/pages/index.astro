---
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/500.css";
import "../styles/global.css";
import fs from "node:fs";

const LINKS = {
  GATEKEEP: "https://gatekeep.vc",
  ATTITEUD: "https://attiteud.com",
  NICHESIM: "https://nichesim.com",
  CLIQUE: "https://clique.tech",
  ZAOBAO: "https://www.zaobao.com.sg/news/singapore/story20240102-1459510",
  LINKEDIN: "https://linkedin.com/in/justincxa",
  GITHUB: "https://github.com/juscxnn",
  SOURCE: "https://github.com/juscxnn/juscxnn.github.io",
};
const EMAIL = "jcxa@proton.me";
const EMAIL_ATTITEUD = "justin@attiteud.com";
const EMAIL_GATEKEEP = "justin@gatekeep.vc";

const hasPortrait = fs.existsSync("./public/portrait.jpg");

const faviconSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><g fill="#2E2D2A">${[0, 60, 120, 180, 240, 300]
  .map((a) => `<ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(${a} 16 16)"/>`)
  .join("")}</g></svg>`;
const favicon = `data:image/svg+xml,${encodeURIComponent(faviconSvg)}`;

const description = "Justin Chua — software, distribution, private markets. Taipei.";
const ogImage = new URL("/og.png", Astro.site);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Justin Chua",
  url: Astro.site?.toString(),
  email: `mailto:${EMAIL}`,
  description,
  jobTitle: "Sales Lead & Product",
  worksFor: { "@type": "Organization", name: "Clique", url: "https://clique.tech" },
  address: { "@type": "PostalAddress", addressLocality: "Taipei" },
  knowsLanguage: ["en", "zh", "fr"],
  sameAs: [LINKS.LINKEDIN, LINKS.GITHUB, LINKS.GATEKEEP, LINKS.ATTITEUD, LINKS.NICHESIM],
});

const stats = [
  {
    eyebrow: "maritime · 2020–24",
    number: "75%",
    line: "of SG harbour craft digitalized · elxa",
    href: LINKS.ZAOBAO,
    link: "联合早报 →",
    lang: "zh-Hans",
  },
  {
    eyebrow: "ai saas · 2022–24",
    number: "2 exits",
    line: "CopyScouts 14x · Podletter '24 · AI Starter #2 PH",
  },
  {
    eyebrow: "clique · 2025– · sales lead + product",
    number: "US$10bn+",
    line: "distributed in 2 years · airdrops · bespoke distribution tooling",
    sub: "75% of top-1000 coins that outsourced development",
    href: LINKS.CLIQUE,
    link: "clique.tech →",
  },
];

const projects = [
  {
    name: "Gatekeep",
    eyebrow: "founder",
    blurb:
      "AI investor personas stress-test your pitch and score it across 12 dimensions. Pass, and the report goes straight to real VCs.",
    href: LINKS.GATEKEEP,
    domain: "gatekeep.vc",
    logo: "/logos/gatekeep.svg",
  },
  {
    name: "Attiteud",
    eyebrow: "founder",
    blurb:
      "Forward-deployment studio — engineers embed in your team, audit workflows and ship AI that sticks. Also acquires small SaaS.",
    href: LINKS.ATTITEUD,
    domain: "attiteud.com",
    logo: "/logos/attiteud.png",
  },
  {
    name: "Nichesim",
    eyebrow: "founder",
    blurb:
      "Thousands of AI personas simulate how a community reacts to your product before you go public.",
    href: LINKS.NICHESIM,
    domain: "nichesim.com",
    logo: "/logos/nichesim.svg",
  },
];

const stack = ["TypeScript", "Node.js", "Next.js", "Astro", "Python", "Postgres", "SQLite", "Electron", "LLM pipelines", "RAG"];

const certs = [
  { cap: "AI4I · AI Singapore", full: "/certs/ai4i.jpg", thumb: "/certs/thumbs/ai4i.jpg" },
  { cap: "CrewAI · agents", full: "/certs/crewai.jpg", thumb: "/certs/thumbs/crewai.jpg" },
  { cap: "UX · Vertical Inst.", full: "/certs/ux.jpg", thumb: "/certs/thumbs/ux.jpg" },
  { cap: "Int'l Business · IBMI", full: "/certs/ibmi.jpg", thumb: "/certs/thumbs/ibmi.jpg" },
  { cap: "CDMS", full: "/certs/cdms.jpg", thumb: "/certs/thumbs/cdms.jpg" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Justin Chua</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.site} />
    <meta name="theme-color" content="#DFDDD7" />
    <meta property="og:title" content="Justin Chua" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#top">skip to content</a>

    <header class="top wrap">
      <a class="wordmark" href="/">Justin Chua</a>
      <span class="lang" title="中文版 coming soon">EN / 繁中</span>
    </header>

    <main id="top" class="wrap">
      <div class="bento">
        <i class="x x-tl" aria-hidden="true"></i>
        <i class="x x-tr" aria-hidden="true"></i>
        <i class="x x-bl" aria-hidden="true"></i>
        <i class="x x-br" aria-hidden="true"></i>

        <section class="cell s9 hero" aria-label="Introduction">
          <p class="eyebrow">TAIPEI · SG HK TW · EN ZH FR</p>
          <h1>I build and distribute software.</h1>
          <p class="roles">founder · sales lead + product @ Clique · pre-IPO broker</p>
          <p class="timeline" tabindex="0" aria-label="Career timeline, scrolls horizontally">
            <span class="t">2014 police SOC</span><span class="dot">·</span><span class="t"
              >2017 robotics sales</span
            ><span class="dot">·</span><span class="t">2020 maritime</span><span class="dot">·</span
            ><span class="t">2022 CopyScouts exit 14x</span><span class="dot">·</span><span class="t"
              >2024 Podletter exit 7x</span
            ><span class="dot">·</span><span class="t">2025 Clique</span><span class="dot">·</span
            ><span class="t t--now">2026 Attiteud + Gatekeep</span>
          </p>
        </section>

        <section class="cell s3 media" aria-label="Portrait">
          {
            hasPortrait ? (
              <img class="portrait" src="/portrait.jpg" alt="Justin Chua" width="620" height="931" />
            ) : (
              <div class="portrait-fallback" aria-hidden="true">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                  <g fill="#2E2D2A">
                    <ellipse cx="16" cy="8.5" rx="4" ry="7.5" />
                    <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(60 16 16)" />
                    <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(120 16 16)" />
                    <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(180 16 16)" />
                    <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(240 16 16)" />
                    <ellipse cx="16" cy="8.5" rx="4" ry="7.5" transform="rotate(300 16 16)" />
                  </g>
                </svg>
              </div>
            )
          }
        </section>

        <p class="label s12">track record</p>

        {
          stats.map((s) => (
            <article class="cell s4 stat" aria-label={s.eyebrow}>
              <p class="cell-eyebrow">{s.eyebrow}</p>
              <p class="stat-number">{s.number}</p>
              <p class="stat-line">{s.line}</p>
              {s.sub && <p class="stat-sub">{s.sub}</p>}
              {s.href && (
                <a class="cell-link" href={s.href} rel="noopener" lang={s.lang}>
                  {s.link}
                </a>
              )}
            </article>
          ))
        }
        <!-- PENDING internal clearance on figures. -->

        <p class="label s12">building now</p>

        {
          projects.map((p) => (
            <a class="cell s4 proj" href={p.href} rel="noopener" aria-label={`${p.name} — ${p.blurb}`}>
              <span class="live" aria-hidden="true" />
              <p class="cell-eyebrow">{p.eyebrow}</p>
              <span class="proj-head">
                <img class="proj-logo" src={p.logo} alt="" width="20" height="20" loading="lazy" decoding="async" />
                <span class="proj-name">{p.name}</span>
              </span>
              <p class="proj-blurb">{p.blurb}</p>
              <p class="cell-link">{p.domain} →</p>
            </a>
          ))
        }

        <p class="label s12">work with me</p>

        <a class="cell s3 route" href={`mailto:${EMAIL_ATTITEUD}`}>
          <p class="route-title">Sell a SaaS · deploy AI</p>
          <p class="route-sub">acquisitions + forward deployment</p>
          <p class="cell-link">justin@attiteud.com →</p>
        </a>

        <a class="cell s3 route" href={`mailto:${EMAIL}`}>
          <p class="route-title">Brand collaboration</p>
          <p class="route-sub">EN · 中文 — Fieldy AI · Plaud · Aethir · Zalora</p>
          <p class="cell-link">media kit →</p>
        </a>

        <section class="cell s6 stackcell" aria-label="Stack">
          <p class="cell-eyebrow">stack</p>
          <ul class="chips">
            {stack.map((s) => <li class="chip">{s}</li>)}
          </ul>
          <p class="cell-eyebrow">certs</p>
          <div class="certs-row">
            {
              certs.map((c) => (
                <a class="cert" href={c.full} rel="noopener" aria-label={`Certificate: ${c.cap}`}>
                  <img src={c.thumb} alt="" width="300" height="212" loading="lazy" decoding="async" />
                  <span class="cert-cap">{c.cap}</span>
                </a>
              ))
            }
          </div>
          <p class="colophon">
            this site: astro static · zero client js · self-hosted type ·
            <a href={LINKS.SOURCE} rel="noopener">view source →</a>
          </p>
        </section>

        <p class="label s12">private markets</p>

        <section class="cell s12 pm" id="private-markets" aria-label="Private markets">
          <div class="pm-text">
            <p class="statement">
              Pre-IPO secondaries and structured private deals, buy-side and sell-side.
            </p>
            <p class="coverage">
              coverage: AI pre-IPO names you'd recognize · share tokenization · listco collateral
              lending
            </p>
          </div>
          <div class="pm-cta">
            <a class="pill" href={`mailto:${EMAIL_GATEKEEP}?subject=Deal%20sheet`}
              >request the deal sheet →</a
            >
            <a class="text-cta" href={LINKS.LINKEDIN} rel="noopener">or LinkedIn →</a>
            <p class="disclaimer">accredited + professional investors · IOI only</p>
          </div>
        </section>
      </div>
    </main>

    <footer class="foot">
      <div class="wrap foot-inner">
        <p class="foot-copy">© Justin Chua · Taipei</p>
        <div class="socials">
          <a href={LINKS.LINKEDIN} aria-label="LinkedIn" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.125 2.062 2.062 0 0 1 0 4.125zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              /></svg
            >
          </a>
          <a href={LINKS.GITHUB} aria-label="GitHub" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              /></svg
            >
          </a>
          <a href={`mailto:${EMAIL}`} aria-label="Email">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path
                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
              /></svg
            >
          </a>
        </div>
        <!-- Digital twin embed: drop the chatbot script here later. It mounts into #twin-mount. -->
        <div id="twin-mount"></div>
      </div>
    </footer>
  </body>
</html>
