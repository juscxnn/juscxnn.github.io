<script>
/* ── text scramble ── */
(function(){
  if(window.matchMedia("(prefers-reduced-motion:reduce)").matches)return;
  const h1=document.querySelector("h1");
  if(!h1||h1.textContent!=="Software, distribution, deals.")return;
  const chars="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%^&*_+-=[]{}|;:?~";
  const text="Software, distribution, deals.",dur=350,stagger=28;
  const start=performance.now();let running=true;
  function tick(now){
    let o="";const e=now-start;
    for(let i=0;i<text.length;i++){
      const d=i*stagger;
      if(e<d){o+=text[i];continue}
      if(e>d+dur){o+=text[i];continue}
      if(text[i]===" "||text[i]==="."||text[i]===","){o+=text[i];continue}
      o+=chars[Math.floor(Math.random()*chars.length)]
    }
    h1.textContent=o;
    if(e<text.length*stagger+dur)requestAnimationFrame(tick)
  }
  requestAnimationFrame(tick)
})();

/* ── command palette ── */
